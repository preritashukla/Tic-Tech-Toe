  "components": {
    "schemas": {
      "DAGNode": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Unique node identifier, e.g. 'node_1' or 'task_1'"
          },
          "tool": {
            "type": "string",
            "title": "Tool",
            "description": "Target MCP tool: jira, github, slack, sheets"
          },
          "action": {
            "type": "string",
            "title": "Action",
            "description": "Tool-specific action to invoke"
          },
          "params": {
            "additionalProperties": true,
            "type": "object",
            "title": "Params",
            "description": "Action parameters, may contain {{template}} refs"
          },
          "depends_on": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Depends On",
            "description": "IDs of upstream dependency nodes"
          },
          "requires_approval": {
            "type": "boolean",
            "title": "Requires Approval",
            "description": "Whether this node needs HITL approval",
            "default": false
          },
          "retry": {
            "$ref": "#/components/schemas/RetryConfig"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name",
            "description": "Human-readable step name"
          },
          "mock_output": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Mock Output",
            "description": "Mock output for demo/testing"
          },
          "timeout_ms": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timeout Ms",
            "description": "Per-node timeout in milliseconds"
          }
        },
        "type": "object",
        "required": [
          "id",
          "tool",
          "action"
        ],
        "title": "DAGNode",
        "description": "A single step in the workflow DAG."
      },
      "ExecuteRequest": {
        "properties": {
          "dag": {
            "$ref": "#/components/schemas/WorkflowDAG-Input",
            "description": "The DAG to execute"
          },
          "auto_approve": {
            "type": "boolean",
            "title": "Auto Approve",
            "description": "If True, skip HITL approval gates (demo mode)",
            "default": true
          },
          "dry_run": {
            "type": "boolean",
            "title": "Dry Run",
            "description": "If True, simulate execution without calling real tools",
            "default": false
          },
          "credentials": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Credentials",
            "description": "User-specific credentials from the ConnectTools dashboard"
          },
          "chat_history": {
            "anyOf": [
              {
                "items": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chat History",
            "description": "Full conversation history to persist"
          }
        },
        "type": "object",
        "required": [
          "dag"
        ],
        "title": "ExecuteRequest",
        "description": "POST /execute \u2014 request body."
      },
      "ExecuteResponse": {
        "properties": {
          "execution_id": {
            "type": "string",
            "title": "Execution Id"
          },
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "total_nodes": {
            "type": "integer",
            "title": "Total Nodes"
          },
          "succeeded": {
            "type": "integer",
            "title": "Succeeded"
          },
          "failed": {
            "type": "integer",
            "title": "Failed"
          },
          "skipped": {
            "type": "integer",
            "title": "Skipped"
          },
          "results": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Results"
          },
          "audit_log": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Audit Log"
          }
        },
        "type": "object",
        "required": [
          "execution_id",
          "success",
          "total_nodes",
          "succeeded",
          "failed",
          "skipped"
        ],
        "title": "ExecuteResponse",
        "description": "POST /execute \u2014 final response (non-streaming)."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PlanRequest": {
        "properties": {
          "user_input": {
            "type": "string",
            "maxLength": 2000,
            "minLength": 5,
            "title": "User Input",
            "description": "Natural language workflow description",
